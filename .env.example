# Server Port
PORT=3001

# Session Secret (Optional - defaults to 'civicpulse-secret' if not set)
SESSION_SECRET=your-session-secret-key-here

# Supabase PostgreSQL Database Connection String
# Get this from Supabase Dashboard > Project Settings > Database > Connection String (URI mode)
# Make sure to replace [YOUR-PASSWORD] with your actual database password.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxx.supabase.co:5432/postgres

# Supabase API Settings (For uploading images to Storage)
# Get these from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
